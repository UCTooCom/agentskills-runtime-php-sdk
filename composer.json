{
    "name": "opencangjie/skills",
    "description": "PHP SDK for AgentSkills Runtime - Install, manage, and execute AI agent skills with built-in runtime support",
    "version": "0.0.3",
    "type": "library",
    "keywords": [
        "agent-skills",
        "skills",
        "ai",
        "agent",
        "runtime",
        "cli",
        "uctoo",
        "cangjiemagic",
        "mcp",
        "llm-tools",
        "skill-runtime",
        "ai-agent-tools"
    ],
    "homepage": "https://github.com/UCTooCom/agentskills-runtime-php-sdk",
    "license": "MIT",
    "authors": [
        {
            "name": "OpenCangJie Team",
            "email": "team@opencangjie.org",
            "homepage": "https://opencangjie.org"
        }
    ],
    "support": {
        "issues": "https://github.com/UCTooCom/agentskills-runtime-php-sdk/issues",
        "source": "https://github.com/UCTooCom/agentskills-runtime-php-sdk",
        "docs": "https://github.com/UCTooCom/agentskills-runtime-php-sdk#readme"
    },
    "funding": [
        {
            "type": "github",
            "url": "https://github.com/sponsors/UCTooCom"
        }
    ],
    "require": {
        "php": ">=8.1",
        "guzzlehttp/guzzle": "^7.8",
        "symfony/console": "^7.0",
        "symfony/process": "^7.0",
        "symfony/filesystem": "^7.0",
        "symfony/yaml": "^7.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5",
        "phpstan/phpstan": "^1.10",
        "squizlabs/php_codesniffer": "^3.9"
    },
    "autoload": {
        "psr-4": {
            "AgentSkills\\": "src/AgentSkills/"
        },
        "files": [
            "src/AgentSkills/functions.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "AgentSkills\\Tests\\": "tests/"
        }
    },
    "bin": [
        "bin/skills"
    ],
    "scripts": {
        "test": "phpunit",
        "test:coverage": "phpunit --coverage-html coverage",
        "analyze": "phpstan analyse src tests --level=8",
        "cs-check": "phpcs --standard=PSR12 src tests",
        "cs-fix": "phpcbf --standard=PSR12 src tests",
        "check": [
            "@cs-check",
            "@analyze",
            "@test"
        ]
    },
    "config": {
        "sort-packages": true,
        "optimize-autoloader": true,
        "allow-plugins": {
            "composer/package-versions-deprecated": true
        }
    },
    "extra": {
        "runtime": {
            "version": "0.0.17",
            "downloadUrl": "https://atomgit.com/uctoo/agentskills-runtime/releases",
            "platforms": {
                "win32-x64": "agentskills-runtime-win-x64.tar.gz",
                "darwin-x64": "agentskills-runtime-darwin-x64.tar.gz",
                "darwin-arm64": "agentskills-runtime-darwin-arm64.tar.gz",
                "linux-x64": "agentskills-runtime-linux-x64.tar.gz",
                "linux-arm64": "agentskills-runtime-linux-arm64.tar.gz"
            }
        },
        "branch-alias": {
            "dev-main": "0.0.x-dev"
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}